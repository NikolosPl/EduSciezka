# Kopiuj ten plik do .env i uzupelnij wartosci.
# Dla Yahoo uzyj hasla aplikacji (App Password), nie zwyklego hasla konta.

EDUSCIEZKA_SMTP_HOST=smtp.mail.yahoo.com
EDUSCIEZKA_SMTP_PORT=587
EDUSCIEZKA_SMTP_USER=edusciezka@yahoo.com
EDUSCIEZKA_SMTP_PASS=TU_WPISZ_HASLO_APLIKACJI_YAHOO

EDUSCIEZKA_ADMIN_PASSWORD=TU_WPISZ_HASLO_ADMINA

# Adres odbiorcy formularza kontaktowego
EDUSCIEZKA_CONTACT_TO=edusciezka@yahoo.com

# Fallback dla funkcji mail() (awaryjnie)
EDUSCIEZKA_MAIL_FROM=no-reply@twojadomena.pl
